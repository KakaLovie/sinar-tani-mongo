<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Daftar — Sinar Tani</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;background:#f0f4f0;}
.left{width:360px;flex-shrink:0;background:linear-gradient(160deg,#1e3d1a,#2d5a27,#3a7a32);padding:48px 36px;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden;}
.left::before{content:'';position:absolute;top:-80px;right:-80px;width:260px;height:260px;border-radius:50%;background:rgba(76,175,80,.12);}
.lc{position:relative;z-index:1;}
.lc i.big{font-size:2.8rem;color:#81c784;display:block;margin-bottom:12px;}
.lc h1{font-size:1.8rem;color:#fff;font-weight:700;margin-bottom:8px;}
.lc p{color:rgba(255,255,255,.7);font-size:.9rem;line-height:1.6;margin-bottom:28px;}
.rc-card{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:13px 15px;display:flex;align-items:center;gap:11px;margin-bottom:10px;}
.rc-icon{font-size:1.4rem;flex-shrink:0;}
.rc-info h4{color:#fff;font-size:.88rem;font-weight:700;margin-bottom:2px;}
.rc-info p{color:rgba(255,255,255,.6);font-size:.76rem;line-height:1.3;}
.right{flex:1;display:flex;align-items:center;justify-content:center;padding:28px 20px;overflow-y:auto;}
.box{width:100%;max-width:500px;}
.box h2{font-size:1.5rem;font-weight:700;color:#1e3d1a;margin-bottom:4px;}
.box p{color:#888;font-size:.88rem;margin-bottom:24px;}
.box p a{color:#2d5a27;font-weight:600;text-decoration:none;}
.err{background:#fee2e2;border-left:4px solid #ef4444;padding:12px 16px;border-radius:10px;color:#991b1b;font-size:.88rem;margin-bottom:18px;display:flex;align-items:center;gap:8px;}
/* Role picker */
.rp{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:18px;}
.rp-opt{position:relative;}
.rp-opt input[type=radio]{position:absolute;opacity:0;width:0;height:0;}
.rp-lbl{display:block;padding:13px 8px;border:2px solid #e5e7eb;border-radius:12px;cursor:pointer;transition:all .25s;text-align:center;}
.rp-em{font-size:1.5rem;display:block;margin-bottom:5px;}
.rp-nm{font-weight:700;font-size:.82rem;color:#333;display:block;margin-bottom:2px;}
.rp-ds{font-size:.7rem;color:#999;display:block;line-height:1.3;}
.rp-opt input:checked+.rp-lbl{border-color:#2d5a27;background:#f0fdf0;}
.rp-opt input:checked+.rp-lbl .rp-nm{color:#2d5a27;}
.rp-lbl:hover{border-color:#4CAF50;background:#f9fdf9;}
/* Fields */
.fg{margin-bottom:14px;}
.fg label{display:block;margin-bottom:5px;font-size:.82rem;font-weight:600;color:#444;}
.fg label span{color:#ef4444;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.iw{position:relative;}
.iw i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#aaa;font-size:.88rem;pointer-events:none;}
.iw input{width:100%;padding:10px 12px 10px 36px;border:2px solid #e5e7eb;border-radius:10px;font-size:.9rem;font-family:inherit;transition:all .2s;background:#fafafa;}
.iw input:focus{outline:none;border-color:#4CAF50;background:#fff;box-shadow:0 0 0 3px rgba(76,175,80,.1);}
.kader-field{display:none;}
.kader-field.show{display:block;}
.btn{width:100%;padding:13px;background:linear-gradient(135deg,#2d5a27,#4CAF50);color:#fff;border:none;border-radius:12px;font-size:.97rem;font-weight:700;cursor:pointer;transition:all .3s;margin-top:4px;}
.btn:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(45,90,39,.35);}
.or{text-align:center;margin:14px 0;color:#ccc;font-size:.82rem;position:relative;}
.or::before,.or::after{content:'';position:absolute;top:50%;width:43%;height:1px;background:#e5e7eb;}
.or::before{left:0;}.or::after{right:0;}
.back{display:flex;align-items:center;justify-content:center;gap:8px;padding:10px;border:2px solid #e5e7eb;border-radius:12px;color:#666;text-decoration:none;font-size:.88rem;transition:all .3s;}
.back:hover{border-color:#4CAF50;color:#2d5a27;}
@media(max-width:860px){.left{display:none;}}
@media(max-width:480px){.rp{grid-template-columns:1fr 1fr;}.fg2{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="left">
  <div class="lc">
    <i class="fas fa-seedling big"></i>
    <h1>SINAR TANI</h1>
    <p>Bergabunglah dengan ribuan petani Indonesia yang sudah merasakan manfaat platform digital pertanian.</p>
    <div class="rc-card"><span class="rc-icon">🌾</span><div class="rc-info"><h4>Petani</h4><p>Akses pasar, harga komoditas, laporan hama, dan kalkulator tani</p></div></div>
    <div class="rc-card"><span class="rc-icon">🤝</span><div class="rc-info"><h4>Kader / Kel. Tani</h4><p>Laporan hama auto-terverifikasi, kelola anggota kelompok</p></div></div>
    <div class="rc-card"><span class="rc-icon">🏛️</span><div class="rc-info"><h4>Dinas Pertanian</h4><p>Kelola program bantuan, pantau kondisi lapangan</p></div></div>
  </div>
</div>
<div class="right">
  <div class="box">
    <h2>Buat Akun Baru</h2>
    <p>Sudah punya akun? <a href="/auth/login">Masuk di sini</a></p>
    <% if (error) { %><div class="err"><i class="fas fa-exclamation-circle"></i><%= error %></div><% } %>
    <form method="POST" action="/auth/register" id="regForm">
      <!-- Pilih peran -->
      <div class="fg">
        <label>Daftar Sebagai <span>*</span></label>
        <div class="rp">
          <div class="rp-opt"><input type="radio" name="peran" id="rPetani" value="petani" <%=(!form.peran||form.peran==='petani')?'checked':''%> onchange="updateRole()"><label class="rp-lbl" for="rPetani"><span class="rp-em">🌾</span><span class="rp-nm">Petani</span><span class="rp-ds">Perorangan</span></label></div>
          <div class="rp-opt"><input type="radio" name="peran" id="rKader"  value="kader"  <%=form.peran==='kader' ?'checked':''%> onchange="updateRole()"><label class="rp-lbl" for="rKader" ><span class="rp-em">🤝</span><span class="rp-nm">Kader</span><span class="rp-ds">Kel. Tani</span></label></div>
          <div class="rp-opt"><input type="radio" name="peran" id="rDinas"  value="dinas"  <%=form.peran==='dinas' ?'checked':''%> onchange="updateRole()"><label class="rp-lbl" for="rDinas" ><span class="rp-em">🏛️</span><span class="rp-nm">Dinas</span><span class="rp-ds">Instansi</span></label></div>
        </div>
      </div>
      <!-- Kelompok tani (kader only) -->
      <div class="fg kader-field" id="kaderField">
        <label>Nama Kelompok Tani <span>*</span></label>
        <div class="iw"><i class="fas fa-users"></i><input type="text" name="kelompok_tani" placeholder="Contoh: Kelompok Tani Maju Jaya" value="<%= form.kelompok_tani||'' %>"></div>
      </div>
      <!-- Nama & HP -->
      <div class="fg2">
        <div class="fg"><label>Nama Lengkap <span>*</span></label><div class="iw"><i class="fas fa-user"></i><input type="text" name="nama" placeholder="Nama lengkap" value="<%= form.nama||'' %>" required></div></div>
        <div class="fg"><label>No. HP</label><div class="iw"><i class="fas fa-phone"></i><input type="tel" id="phoneInput" name="no_hp" placeholder="08xxxxxxxxxx" value="<%= form.no_hp||'' %>"></div></div>
      </div>
      <!-- Email -->
      <div class="fg"><label>Email <span>*</span></label><div class="iw"><i class="fas fa-envelope"></i><input type="email" id="emailInput" name="email" placeholder="email@contoh.com" value="<%= form.email||'' %>" required autocomplete="email"></div></div>
      <!-- Provinsi & Kabupaten -->
      <div class="fg2">
        <div class="fg"><label>Provinsi</label><div class="iw"><i class="fas fa-map-marker-alt"></i><input type="text" name="provinsi" placeholder="Jawa Barat" value="<%= form.provinsi||'' %>"></div></div>
        <div class="fg"><label>Kabupaten/Kota</label><div class="iw"><i class="fas fa-city"></i><input type="text" name="kabupaten" placeholder="Bandung" value="<%= form.kabupaten||'' %>"></div></div>
      </div>
      <!-- Password -->
      <div class="fg2">
        <div class="fg"><label>Password <span>*</span></label><div class="iw"><i class="fas fa-lock"></i><input type="password" name="password" id="pw" placeholder="Min. 8 karakter" required></div>
          <div id="passwordStrength" style="margin-top:8px;display:none;">
            <div style="height:4px;background:#f3f4f6;border-radius:2px;overflow:hidden;">
              <div id="strengthBar" style="height:100%;width:0;transition:all .3s;"></div>
            </div>
            <div class="strength-text" style="font-size:.7rem;margin-top:3px;font-weight:600;"></div>
          </div>
        </div>
        <div class="fg"><label>Konfirmasi Password <span>*</span></label><div class="iw"><i class="fas fa-lock"></i><input type="password" name="konfirmasi_password" id="pw2" placeholder="Ulangi password" required></div></div>
      </div>
      <button type="submit" class="btn"><i class="fas fa-user-plus"></i> Buat Akun</button>
      <div class="or">atau</div>
      <a href="/" class="back"><i class="fas fa-arrow-left"></i> Kembali ke Beranda</a>
    </form>
  </div>
</div>
<script>
function updateRole(){
  const p=document.querySelector('input[name=peran]:checked')?.value;
  const kf=document.getElementById('kaderField');
  const inp=kf.querySelector('input');
  if(p==='kader'){kf.classList.add('show');inp.required=true;}
  else{kf.classList.remove('show');inp.required=false;inp.value='';}
}

// Password strength checker
function checkPasswordStrength(password) {
  let strength = 0;
  const checks = {
    length: password.length >= 8,
    lowercase: /[a-z]/.test(password),
    uppercase: /[A-Z]/.test(password),
    number: /[0-9]/.test(password),
    special: /[^a-zA-Z0-9]/.test(password)
  };
  
  strength = Object.values(checks).filter(Boolean).length;
  
  const indicators = {
    veryWeak: { width: '20%', color: '#ef4444', text: 'Sangat Lemah' },
    weak: { width: '40%', color: '#f97316', text: 'Lemah' },
    medium: { width: '60%', color: '#f59e0b', text: 'Cukup' },
    strong: { width: '80%', color: '#84cc16', text: 'Kuat' },
    veryStrong: { width: '100%', color: '#22c55e', text: 'Sangat Kuat' }
  };
  
  if (strength <= 1) return indicators.veryWeak;
  if (strength === 2) return indicators.weak;
  if (strength === 3) return indicators.medium;
  if (strength === 4) return indicators.strong;
  return indicators.veryStrong;
}

// Update password strength indicator
function updatePasswordStrength() {
  const password = document.getElementById('pw').value;
  const strengthEl = document.getElementById('passwordStrength');
  const strengthBar = document.getElementById('strengthBar');
  
  if (!password) {
    strengthEl.style.display = 'none';
    return;
  }
  
  const strength = checkPasswordStrength(password);
  strengthEl.style.display = 'block';
  strengthBar.style.width = strength.width;
  strengthBar.style.background = strength.color;
  strengthEl.querySelector('.strength-text').textContent = strength.text;
  strengthEl.querySelector('.strength-text').style.color = strength.color;
}

// Validate email format
function validateEmail(email) {
  const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return re.test(email);
}

// Validate phone number (Indonesian format)
function validatePhone(phone) {
  if (!phone) return true; // Optional field
  const re = /^(08|628)[0-9]{8,11}$/;
  return re.test(phone.replace(/[\s-]/g, ''));
}

// Real-time validation
function setupValidation() {
  const emailInput = document.getElementById('emailInput');
  const phoneInput = document.getElementById('phoneInput');
  const pwInput = document.getElementById('pw');
  const pw2Input = document.getElementById('pw2');
  
  // Email validation
  emailInput?.addEventListener('blur', function() {
    if (this.value && !validateEmail(this.value)) {
      this.style.borderColor = '#ef4444';
      this.setCustomValidity('Format email tidak valid');
    } else {
      this.style.borderColor = this.value ? '#4CAF50' : '';
      this.setCustomValidity('');
    }
  });
  
  emailInput?.addEventListener('input', function() {
    if (this.style.borderColor === 'rgb(239, 68, 68)') {
      if (validateEmail(this.value)) {
        this.style.borderColor = '#4CAF50';
        this.setCustomValidity('');
      }
    }
  });
  
  // Phone validation
  phoneInput?.addEventListener('blur', function() {
    if (!validatePhone(this.value)) {
      this.style.borderColor = '#ef4444';
      this.setCustomValidity('Format nomor HP tidak valid. Gunakan format: 08xxxxxxxxxx');
    } else {
      this.style.borderColor = this.value ? '#4CAF50' : '';
      this.setCustomValidity('');
    }
  });
  
  // Password strength
  pwInput?.addEventListener('input', updatePasswordStrength);
  
  // Confirm password
  pw2Input?.addEventListener('input', function() {
    if (this.value && this.value !== pwInput.value) {
      this.style.borderColor = '#ef4444';
      this.setCustomValidity('Password tidak cocok');
    } else if (this.value === pwInput.value) {
      this.style.borderColor = '#4CAF50';
      this.setCustomValidity('');
    } else {
      this.style.borderColor = '';
      this.setCustomValidity('');
    }
  });
}

// Form submission validation
document.getElementById('regForm')?.addEventListener('submit', function(e) {
  const errors = [];
  
  const nama = this.querySelector('[name="nama"]').value.trim();
  const email = this.querySelector('[name="email"]').value.trim();
  const password = this.querySelector('[name="password"]').value;
  const confirmPassword = this.querySelector('[name="konfirmasi_password"]').value;
  const phone = this.querySelector('[name="no_hp"]')?.value || '';
  const peran = this.querySelector('[name="peran"]:checked')?.value;
  const kelompokTani = this.querySelector('[name="kelompok_tani"]')?.value || '';
  
  if (nama.length < 2) errors.push('Nama minimal 2 karakter');
  if (!validateEmail(email)) errors.push('Format email tidak valid');
  if (password.length < 8) errors.push('Password minimal 8 karakter');
  if (password !== confirmPassword) errors.push('Konfirmasi password tidak cocok');
  if (!['petani','kader','dinas'].includes(peran)) errors.push('Peran tidak valid');
  if (peran === 'kader' && !kelompokTani.trim()) errors.push('Nama kelompok tani wajib diisi');
  if (!validatePhone(phone)) errors.push('Format nomor HP tidak valid');
  
  if (errors.length) {
    e.preventDefault();
    alert('❌ Validasi gagal:\n\n• ' + errors.join('\n• '));
  }
});

// Initialize on load
updateRole();
setupValidation();
</script>
</body>
</html>
