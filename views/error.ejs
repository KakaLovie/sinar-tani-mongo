<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Error — Sinar Tani</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f0f4f0;}
.box{text-align:center;padding:48px;background:#fff;border-radius:20px;box-shadow:0 4px 24px rgba(0,0,0,.08);max-width:480px;width:90%;}
.icon{font-size:4rem;color:#ef4444;margin-bottom:20px;}
h1{font-size:1.5rem;color:#1e3d1a;margin-bottom:12px;}
p{color:#666;font-size:.95rem;line-height:1.6;margin-bottom:28px;}
a{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:linear-gradient(135deg,#2d5a27,#4CAF50);color:#fff;border-radius:25px;text-decoration:none;font-weight:600;transition:all .3s;}
a:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(45,90,39,.3);}
</style>
</head>
<body>
<div class="box">
  <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
  <h1>Oops! Terjadi Kesalahan</h1>
  <p><%= message || 'Halaman tidak ditemukan atau terjadi kesalahan pada server.' %></p>
  <a href="/dashboard"><i class="fas fa-home"></i> Kembali ke Dashboard</a>
</div>
</body>
</html>
