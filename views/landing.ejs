<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sinar Tani - Platform Digital Rantai Pasok Pertanian</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #16a34a;
            --primary-dark: #15803d;
            --primary-light: #22c55e;
            --secondary: #7c3aed;
            --accent: #f59e0b;
            --bg: #f0f9f4;
            --card: #ffffff;
            --text: #1f2937;
            --muted: #6b7280;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            line-height: 1.7; color: var(--text);
            background: var(--bg);
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        /* Animated Background */
        .bg-animation {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: -1;
            background: linear-gradient(135deg, #f0f9f4 0%, #ecfdf5 50%, #f0fdf4 100%);
        }
        .bg-shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.5;
            animation: float 20s infinite ease-in-out;
        }
        .bg-shape:nth-child(1) {
            width: 400px; height: 400px;
            background: rgba(22, 163, 74, 0.3);
            top: -100px; left: -100px;
            animation-delay: 0s;
        }
        .bg-shape:nth-child(2) {
            width: 300px; height: 300px;
            background: rgba(124, 58, 237, 0.2);
            top: 50%; right: -50px;
            animation-delay: -7s;
        }
        .bg-shape:nth-child(3) {
            width: 350px; height: 350px;
            background: rgba(245, 158, 11, 0.2);
            bottom: -80px; left: 30%;
            animation-delay: -14s;
        }
        @keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            25% { transform: translate(30px, -30px) scale(1.1); }
            50% { transform: translate(-20px, 20px) scale(0.9); }
            75% { transform: translate(20px, 30px) scale(1.05); }
        }

        /* Navigation */
        nav {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            padding: 1rem 0;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
            border-bottom: 1px solid rgba(22, 163, 74, 0.1);
            transition: all 0.3s ease;
        }
        nav.scrolled {
            padding: 0.7rem 0;
            background: rgba(255, 255, 255, 0.98);
        }
        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo i {
            color: var(--primary);
            font-size: 2rem;
            -webkit-text-fill-color: var(--primary);
        }
        .nav-links {
            display: flex;
            list-style: none;
            gap: 2rem;
            align-items: center;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text);
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            position: relative;
            padding: 8px 0;
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            transition: width 0.3s ease;
        }
        .nav-links a:hover { color: var(--primary); }
        .nav-links a:hover::after { width: 100%; }
        
        .nav-auth {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .btn-nav-login {
            padding: 10px 24px;
            border: 2px solid var(--primary);
            color: var(--primary);
            background: transparent;
            border-radius: 25px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-nav-login:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(22, 163, 74, 0.3);
        }
        .btn-nav-register {
            padding: 10px 24px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border-radius: 25px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
        }
        .btn-nav-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(22, 163, 74, 0.4);
        }
        .nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 20px;
            background: linear-gradient(135deg, #dcfce7, #86efac);
            border-radius: 25px;
            text-decoration: none;
            color: var(--primary-dark);
            font-weight: 700;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }
        .nav-user:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(22, 163, 74, 0.3);
        }
        .nav-user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 0.9rem;
        }

        /* Hero Section */
        .hero {
            padding: 180px 0 120px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 20px;
            background: linear-gradient(135deg, #dcfce7, #86efac);
            color: var(--primary-dark);
            border-radius: 25px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 24px;
            animation: fadeInDown 0.8s ease;
        }
        .hero h1 {
            font-size: 4rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 24px;
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: fadeInUp 1s ease;
        }
        .hero p {
            font-size: 1.25rem;
            color: var(--muted);
            max-width: 700px;
            margin: 0 auto 40px;
            animation: fadeInUp 1s ease 0.2s both;
        }
        .hero-buttons {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
            animation: fadeInUp 1s ease 0.4s both;
        }
        .cta-button {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 40px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.05rem;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(22, 163, 74, 0.3);
        }
        .cta-button:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(22, 163, 74, 0.4);
        }
        .cta-button-outline {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 40px;
            background: white;
            color: var(--primary);
            text-decoration: none;
            border-radius: 50px;
            font-weight: 800;
            font-size: 1.05rem;
            border: 2px solid var(--primary);
            transition: all 0.3s ease;
        }
        .cta-button-outline:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-4px);
        }

        /* Stats Section */
        .stats-section {
            background: white;
            padding: 60px 0;
            margin: 40px 0;
            border-radius: 24px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 32px;
        }
        .stat-item {
            text-align: center;
            padding: 24px;
            border-radius: 16px;
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
            transition: all 0.3s ease;
        }
        .stat-item:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(22, 163, 74, 0.2);
        }
        .stat-icon {
            width: 70px;
            height: 70px;
            margin: 0 auto 16px;
            border-radius: 18px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: white;
        }
        .stat-number {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--primary-dark);
            margin-bottom: 8px;
        }
        .stat-label {
            font-size: 0.95rem;
            color: var(--muted);
            font-weight: 600;
        }

        /* Features Section */
        .features {
            padding: 100px 0;
        }
        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }
        .section-tag {
            display: inline-block;
            padding: 8px 20px;
            background: linear-gradient(135deg, #dbeafe, #93c5fd);
            color: #1d4ed8;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        .section-header h2 {
            font-size: 2.8rem;
            font-weight: 900;
            color: var(--text);
            margin-bottom: 16px;
        }
        .section-header p {
            font-size: 1.1rem;
            color: var(--muted);
            max-width: 600px;
            margin: 0 auto;
        }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 28px;
        }
        .feature-card {
            background: white;
            padding: 32px;
            border-radius: 24px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
            border: 1px solid rgba(0, 0, 0, 0.05);
            position: relative;
            overflow: hidden;
        }
        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }
        .feature-card:hover::before {
            transform: scaleX(1);
        }
        .feature-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
        }
        .feature-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 20px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            transition: all 0.4s ease;
        }
        .feature-card:nth-child(1) .feature-icon { background: linear-gradient(135deg, #dcfce7, #86efac); color: var(--primary); }
        .feature-card:nth-child(2) .feature-icon { background: linear-gradient(135deg, #dbeafe, #93c5fd); color: #3b82f6; }
        .feature-card:nth-child(3) .feature-icon { background: linear-gradient(135deg, #fef3c7, #fcd34d); color: var(--accent); }
        .feature-card:nth-child(4) .feature-icon { background: linear-gradient(135deg, #fee2e2, #fca5a5); color: var(--r500); }
        .feature-card:nth-child(5) .feature-icon { background: linear-gradient(135deg, #e0e7ff, #a5b4fc); color: #7c3aed; }
        .feature-card:nth-child(6) .feature-icon { background: linear-gradient(135deg, #ffedd5, #fdba74); color: #ea580c; }
        .feature-card:hover .feature-icon {
            transform: scale(1.1) rotate(5deg);
        }
        .feature-card h3 {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 12px;
        }
        .feature-card p {
            color: var(--muted);
            line-height: 1.6;
        }

        /* CTA Section */
        .cta-section {
            padding: 100px 0;
            text-align: center;
        }
        .cta-box {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            padding: 60px 40px;
            border-radius: 32px;
            color: white;
            position: relative;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(22, 163, 74, 0.3);
        }
        .cta-box::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }
        .cta-box::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
        }
        .cta-box h2 {
            font-size: 2.5rem;
            font-weight: 900;
            margin-bottom: 16px;
            position: relative;
        }
        .cta-box p {
            font-size: 1.1rem;
            opacity: 0.95;
            margin-bottom: 32px;
            position: relative;
        }
        .cta-box .btn-nav-register {
            background: white;
            color: var(--primary);
            border: none;
            display: inline-flex;
            margin: 0 auto;
        }
        .cta-box .btn-nav-register:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
        }

        /* Footer */
        footer {
            background: var(--text);
            color: white;
            padding: 40px 0;
            text-align: center;
        }
        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        .footer-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.4rem;
            font-weight: 800;
        }
        .footer-logo i {
            color: var(--primary-light);
            font-size: 1.8rem;
        }
        .footer-text {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
        }

        /* About Section */
        .about-section {
            padding: 100px 0;
            background: linear-gradient(180deg, transparent 0%, rgba(22, 163, 74, 0.03) 100%);
        }
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: start;
        }
        .developer-card {
            background: white;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(22, 163, 74, 0.1);
        }
        .developer-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
        }
        .developer-avatar-wrapper {
            width: 140px;
            height: 140px;
            margin: 0 auto 24px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-light), var(--secondary));
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: pulse-glow 3s infinite ease-in-out;
        }
        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 20px rgba(22, 163, 74, 0.4); }
            50% { box-shadow: 0 0 40px rgba(22, 163, 74, 0.6); }
        }
        .developer-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: linear-gradient(135deg, #1f2937, #374151);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3.5rem;
            color: white;
            font-weight: 900;
            border: 4px solid white;
        }
        .developer-name {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--text);
            margin-bottom: 8px;
        }
        .developer-title {
            text-align: center;
            font-size: 1rem;
            color: var(--primary);
            font-weight: 700;
            margin-bottom: 20px;
            display: inline-block;
            padding: 6px 16px;
            background: linear-gradient(135deg, #dcfce7, #86efac);
            border-radius: 20px;
        }
        .developer-school {
            text-align: center;
            font-size: 0.95rem;
            color: var(--muted);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .developer-school i {
            color: var(--primary);
        }
        .welcome-message {
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
            padding: 24px;
            border-radius: 16px;
            border-left: 4px solid var(--primary);
            margin-top: 20px;
        }
        .welcome-message p {
            font-size: 0.95rem;
            line-height: 1.8;
            color: var(--text);
            font-style: italic;
        }
        .welcome-message .quote-icon {
            font-size: 2rem;
            color: var(--primary);
            opacity: 0.3;
            margin-bottom: 8px;
        }
        .vision-mission-card {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .vm-card {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(22, 163, 74, 0.1);
            transition: all 0.3s ease;
        }
        .vm-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 40px rgba(22, 163, 74, 0.15);
        }
        .vm-card.vision {
            border-top: 4px solid var(--primary);
        }
        .vm-card.mission {
            border-top: 4px solid var(--secondary);
        }
        .vm-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }
        .vm-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }
        .vision .vm-icon {
            background: linear-gradient(135deg, #dcfce7, #86efac);
            color: var(--primary);
        }
        .mission .vm-icon {
            background: linear-gradient(135deg, #e0e7ff, #a5b4fc);
            color: var(--secondary);
        }
        .vm-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--text);
        }
        .vm-content {
            color: var(--muted);
            line-height: 1.8;
        }
        .vm-content ul {
            list-style: none;
            padding-left: 0;
        }
        .vm-content li {
            padding: 8px 0 8px 28px;
            position: relative;
        }
        .vm-content li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--primary);
            font-weight: 900;
            font-size: 1.1rem;
        }
        .timeline-card {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(22, 163, 74, 0.1);
            margin-top: 24px;
        }
        .timeline-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }
        .timeline-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            background: linear-gradient(135deg, #fef3c7, #fcd34d);
            color: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }
        .timeline-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--text);
        }
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 8px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(180deg, var(--primary), var(--secondary));
        }
        .timeline-item {
            position: relative;
            padding-bottom: 24px;
        }
        .timeline-item:last-child {
            padding-bottom: 0;
        }
        .timeline-dot {
            position: absolute;
            left: -26px;
            top: 4px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: white;
            border: 3px solid var(--primary);
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.1);
        }
        .timeline-item.active .timeline-dot {
            background: var(--primary);
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.2);
            animation: timeline-pulse 2s infinite;
        }
        @keyframes timeline-pulse {
            0%, 100% { box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.2); }
            50% { box-shadow: 0 0 0 8px rgba(22, 163, 74, 0.1); }
        }
        .timeline-date {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 4px;
        }
        .timeline-content {
            font-size: 0.95rem;
            color: var(--muted);
            line-height: 1.6;
        }
        .timeline-content strong {
            color: var(--text);
        }

        /* Responsive */
        @media (max-width: 968px) {
            .about-grid {
