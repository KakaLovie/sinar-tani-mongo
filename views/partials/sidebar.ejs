<aside class="sidebar">
    <div class="sidebar-header">
        <h2><i class="fas fa-seedling"></i> SINAR TANI</h2>
        <% if (user) { %>
        <div class="sidebar-user">
            <div class="su-avatar"><%= user.nama.charAt(0).toUpperCase() %></div>
            <div class="su-info">
                <span class="su-name"><%= user.nama.split(' ')[0] %></span>
                <span class="su-role role-<%= user.peran %>">
                    <%- {admin:'👑 Admin',petani:'🌾 Petani',kader:'🤝 Kader',dinas:'🏛️ Dinas'}[user.peran]||user.peran %>
                </span>
            </div>
        </div>
        <% } %>
    </div>

    <ul class="sidebar-menu">
        <li><a href="/dashboard"       class="<%= locals.active==='dashboard'       ?'active':'' %>"><i class="fas fa-home"></i> Dashboard</a></li>
        <li><a href="/kalkulator-tani" class="<%= locals.active==='kalkulator-tani' ?'active':'' %>"><i class="fas fa-calculator"></i> Kalkulator Tani</a></li>
        <li><a href="/k-map"           class="<%= locals.active==='k-map'           ?'active':'' %>"><i class="fas fa-satellite-dish"></i> K-MAP & Radar</a></li>
        <li><a href="/pasar-tani"      class="<%= locals.active==='pasar-tani'      ?'active':'' %>"><i class="fas fa-store"></i> Pasar Tani</a></li>
        <li><a href="/kelas-tani"      class="<%= locals.active==='kelas-tani'      ?'active':'' %>"><i class="fas fa-graduation-cap"></i> Kelas Tani</a></li>
        <li><a href="/bantuan-dinas"   class="<%= locals.active==='bantuan-dinas'   ?'active':'' %>"><i class="fas fa-hands-helping"></i> Bantuan Dinas</a></li>
        <li><a href="/profil"          class="<%= locals.active==='profil'          ?'active':'' %>"><i class="fas fa-user-circle"></i> Profil Saya</a></li>
        <% if (user && user.peran === 'admin') { %>
        <li class="sb-divider"></li>
        <li><a href="/admin" class="<%= locals.active==='admin' ?'active':'' %> admin-link"><i class="fas fa-shield-alt"></i> Panel Admin</a></li>
        <% } %>
        <li class="sb-divider"></li>
        <li>
            <% if (user) { %>
            <form action="/auth/logout" method="POST" style="margin:0">
                <button type="submit" class="sb-logout"><i class="fas fa-sign-out-alt"></i> Keluar</button>
            </form>
            <% } else { %>
            <a href="/auth/login"><i class="fas fa-sign-in-alt"></i> Masuk / Daftar</a>
            <% } %>
        </li>
    </ul>
</aside>

<style>
.sidebar{position:fixed;left:0;top:0;width:260px;height:100vh;background:linear-gradient(180deg,#2d5a27,#1e3d1a);color:#fff;padding:20px;overflow-y:auto;z-index:1000;}
.sidebar-header{text-align:center;padding:16px 0 20px;border-bottom:1px solid rgba(255,255,255,.12);}
.sidebar-header h2{font-size:1.4rem;display:flex;align-items:center;justify-content:center;gap:8px;}
.sidebar-user{display:flex;align-items:center;gap:10px;margin-top:14px;padding:10px;background:rgba(255,255,255,.08);border-radius:12px;}
.su-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#4CAF50,#81c784);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;}
.su-info{display:flex;flex-direction:column;min-width:0;}
.su-name{font-weight:600;font-size:.88rem;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.su-role{font-size:.7rem;padding:2px 8px;border-radius:10px;margin-top:3px;width:fit-content;font-weight:600;}
.role-admin{background:rgba(239,68,68,.3);color:#fca5a5;}
.role-petani{background:rgba(76,175,80,.3);color:#86efac;}
.role-kader{background:rgba(59,130,246,.3);color:#93c5fd;}
.role-dinas{background:rgba(168,85,247,.3);color:#d8b4fe;}
.sidebar-menu{list-style:none;margin-top:24px;}
.sidebar-menu li{margin-bottom:6px;}
.sidebar-menu a{display:flex;align-items:center;gap:12px;padding:11px 14px;color:rgba(255,255,255,.75);text-decoration:none;border-radius:10px;transition:all .25s;font-size:.92rem;}
.sidebar-menu a:hover,.sidebar-menu a.active{background:rgba(255,255,255,.12);color:#fff;transform:translateX(4px);}
.sidebar-menu i{width:18px;text-align:center;}
.sb-divider{height:1px;background:rgba(255,255,255,.1);margin:10px 0;pointer-events:none;}
.sb-logout{display:flex;align-items:center;gap:12px;padding:11px 14px;width:100%;color:rgba(255,255,255,.7);background:transparent;border:none;border-radius:10px;cursor:pointer;font-size:.92rem;font-family:inherit;transition:all .25s;text-align:left;}
.sb-logout:hover{background:rgba(239,68,68,.2);color:#fca5a5;}
.admin-link{color:rgba(252,211,77,.9)!important;}
.admin-link:hover,.admin-link.active{background:rgba(252,211,77,.15)!important;color:#fcd34d!important;}
</style>
